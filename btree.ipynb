    "class Node:\n",
    "    def __init__(self, key=None, leaf=True):\n",
    "        self.keys = []\n",
    "        self.children = []\n",
    "        self.leaf = leaf\n",
    "\n",
    "class btree:\n",
    "    def __init__(self, t):\n",
    "        self.root = Node(leaf=True)\n",
    "        self.t = t\n",
    "\n",
    "a = btree(3)\n",
    "print(a.t)"
